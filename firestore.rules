rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isEmployee() {
      let role = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      return isSignedIn() && (role == 'admin' || role == 'employee');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Rules
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(userId) && 
        incoming().keys().hasAll(['uid', 'name', 'email', 'role']) &&
        incoming().role == 'employee'; // Default new users to employee or similar
      allow update: if isAdmin() || (isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role']));
    }

    // Product Rules
    match /products/{productId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    // Category Rules
    match /categories/{categoryId} {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }

    // Sale Rules
    match /sales/{saleId} {
      allow read: if isEmployee();
      allow create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Customer Rules
    match /customers/{customerId} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }

    // Supplier Rules
    match /suppliers/{supplierId} {
      allow read: if isEmployee();
      allow create, update: if isEmployee();
      allow delete: if isAdmin();
    }

    // Stock Movement Rules
    match /stockMovements/{movementId} {
      allow read: if isEmployee();
      allow create: if isEmployee();
      allow update, delete: if isAdmin();
    }

    // Settings Rules
    match /settings/system {
      allow read: if isEmployee();
      allow write: if isAdmin();
    }
  }
}
