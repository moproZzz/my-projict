{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "employee"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Inventory product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "categoryId": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "stock": { "type": "number" },
        "image": { "type": "string" },
        "barcode": { "type": "string" },
        "minStockAlert": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "categoryId", "purchasePrice", "sellingPrice", "stock"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record",
      "type": "object",
      "properties": {
        "customerId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "taxAmount": { "type": "number" },
        "discountAmount": { "type": "number" },
        "finalAmount": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "invoiceNumber": { "type": "string" }
      },
      "required": ["items", "totalAmount", "finalAmount", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Supplier information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "company": { "type": "string" }
      },
      "required": ["name"]
    },
    "StockMovement": {
      "title": "StockMovement",
      "description": "Record of stock increases or decreases",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out", "audit"] },
        "quantity": { "type": "number" },
        "reason": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "type", "quantity", "userId", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "System wide settings",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "currency": { "type": "string" },
        "taxRate": { "type": "number" },
        "logo": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/products/{productId}": { "schema": "Product", "description": "Product catalog" },
    "/categories/{categoryId}": { "schema": "Category", "description": "Product categories" },
    "/sales/{saleId}": { "schema": "Sale", "description": "Sales transactions" },
    "/customers/{customerId}": { "schema": "Customer", "description": "Customer directory" },
    "/suppliers/{supplierId}": { "schema": "Supplier", "description": "Supplier directory" },
    "/stockMovements/{movementId}": { "schema": "StockMovement", "description": "Inventory logs" },
    "/settings/system": { "schema": "Settings", "description": "System settings" }
  }
}
